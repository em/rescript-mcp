{
  "name": "rescript-mcp",
  "version": "0.2.0",
  "description": "ReScript bindings for the public MCP TypeScript SDK split packages",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/em/rescript-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/em/rescript-mcp/issues"
  },
  "homepage": "https://github.com/em/rescript-mcp",
  "keywords": [
    "rescript",
    "mcp",
    "modelcontextprotocol",
    "bindings",
    "sdk"
  ],
  "files": [
    "README.md",
    "LICENSE",
    "rescript.json",
    "src/**/*.mjs",
    "src/**/*.res",
    "src/**/*.resi"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/Mcp.mjs",
    "./auth": "./src/auth/McpAuth.mjs",
    "./protocol": "./src/protocol/McpProtocol.mjs",
    "./core": "./src/core/McpCore.mjs",
    "./shared": "./src/shared/McpShared.mjs",
    "./server": "./src/server/McpServerBindings.mjs",
    "./client": "./src/client/McpClientBindings.mjs",
    "./transports": "./src/transports/McpTransports.mjs"
  },
  "scripts": {
    "build": "rescript build",
    "verify:generated": "npm run build && git diff --exit-code -- ':(glob)src/**/*.mjs' ':(glob)tests/**/*.mjs'",
    "changeset": "changeset",
    "clean": "rescript clean",
    "release": "node ./scripts/releaseLocalRefusal.mjs",
    "release:ci": "node ./scripts/releasePublish.mjs",
    "test": "npm run build && vitest run --environment node --coverage",
    "test:watch": "npm run build && vitest --environment node --coverage",
    "version-packages": "changeset version && npm install --package-lock-only"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "rescript-nodejs": "^16.1.0",
    "rescript-schema": "^9.5.1",
    "rescript-webapi": "^0.10.0"
  },
  "peerDependencies": {
    "@modelcontextprotocol/client": "2.0.0-alpha.2",
    "@modelcontextprotocol/node": "2.0.0-alpha.2",
    "@modelcontextprotocol/server": "2.0.0-alpha.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@modelcontextprotocol/client": "2.0.0-alpha.2",
    "@modelcontextprotocol/node": "2.0.0-alpha.2",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "@vitest/coverage-v8": "^3.1.4",
    "rescript": "^12.2.0",
    "rescript-schema-ppx": "^9.0.1",
    "rescript-vitest": "^2.1.1",
    "vitest": "^3.1.4"
  }
}
